# Copy to .env and fill in to swap mock backends for real services.
# Any unset backend defaults to the deterministic mock (runs anywhere).

# --- backend selection (mock | real) ---------------------------------------
# SANDBOX=openshell
# ASSESSOR=hiddenlayer
# LLM=nemotron

# --- NVIDIA OpenShell -------------------------------------------------------
# OPENSHELL_ENDPOINT=https://openshell.example/api
# OPENSHELL_KEY=

# --- HiddenLayer ------------------------------------------------------------
# HIDDENLAYER_KEY=
# HIDDENLAYER_PROJECT=

# --- Nemotron on vLLM (OpenAI-compatible) -----------------------------------
# NEMOTRON_BASE_URL=http://vllm:8000
# NEMOTRON_KEY=not-needed
# NEMOTRON_MODEL=nemotron

# For the gpu compose profile that pulls the model:
# HF_TOKEN=
