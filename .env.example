# Copy to .env and fill in to swap mock backends for real services.
# Any unset backend defaults to the deterministic mock (runs anywhere).

# --- backend selection (mock | real) ---------------------------------------
# SANDBOX=openshell
# ASSESSOR=hiddenlayer
# LLM=nemotron

# --- NVIDIA OpenShell -------------------------------------------------------
# OPENSHELL_ENDPOINT=https://openshell.example/api
# OPENSHELL_KEY=

# --- HiddenLayer Runtime Security -------------------------------------------
# ASSESSOR=hiddenlayer                        # use the live red team
# Needs the optional extra:  uv sync --extra hiddenlayer
# Get client_id/secret from the HiddenLayer console (Settings → API Keys).
# HIDDENLAYER_CLIENT_ID=
# HIDDENLAYER_CLIENT_SECRET=                   # export, don't commit
# HIDDENLAYER_ENV=prod-us                      # prod-us | prod-eu
# HIDDENLAYER_PROJECT=                         # optional hl_project_id

# --- Nemotron / any vLLM OpenAI-compatible endpoint -------------------------
# Optional. When set, the LLM proposes which finding to fix and narrates the
# root cause; its choice is validated against known remediations and falls back
# to the deterministic heuristic when unusable — so the loop always converges,
# even behind a tiny model. Keep the key out of git; export it in your shell.
# LLM=nemotron
# NEMOTRON_BASE_URL=http://YOUR_VLLM_HOST:8000    # your vLLM endpoint
# NEMOTRON_MODEL=Qwen/Qwen2.5-0.5B-Instruct       # whatever /v1/models serves
# NEMOTRON_KEY=                                    # export, don't commit
# NEMOTRON_TIMEOUT=20                              # seconds; falls back if slow

# For the gpu compose profile that pulls a model locally instead:
# HF_TOKEN=
